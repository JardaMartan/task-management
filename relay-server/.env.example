# Relay Server — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# Port the server listens on (default: 3001; Cloud Run injects 8080 automatically)
PORT=3001

# Comma-separated list of allowed Webex org IDs.
# Leave empty to allow all connections (suitable for local development only).
# Example: ALLOWED_ORG_IDS=1234abcd-5678-efgh-ijkl-mnopqrstuvwx,aaaa-bbbb-cccc
ALLOWED_ORG_IDS=

# CORS origin for the static /crm-tab-manager/ pages (optional; unused by the
# WebSocket layer which relies on session-scoped routing instead).
CORS_ORIGIN=*
