# Cloud Function environment variables
# Copy to .env and fill in your values. Never commit .env to version control.

# Gmail push notification target
PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-inbound
SUPPORT_EMAIL=support@yourcompany.com

# Webex Connect webhook URL to receive inbound emails
WEBEX_CONNECT_INBOUND_WEBHOOK=https://inbound.us1.webexconnect.io/v1/your-webhook-id

# AI enrichment provider: gemini | openai
AI_PROVIDER=gemini
AI_API_KEY=your-ai-api-key-here
AI_MODEL=gemini-1.5-flash

# CORS origin for token broker (set to your widget host in production)
CORS_ORIGIN=*

# Google service account credentials (path to JSON key file, or use ADC in Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
