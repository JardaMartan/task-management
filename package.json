{
    "name": "task-management",
    "version": "1.0.0",
    "description": "Task Management WebexCC Widget",
    "main": "src/index.jsx",
    "scripts": {
        "build": "rollup -c && node scripts/inline-fonts.js && cp src/panel-layout-headless.js dist/panel-layout-headless.js",
        "build:standalone": "BUILD_MODE=self-contained rollup -c && node scripts/inline-fonts.js && cp src/panel-layout-headless.js dist/panel-layout-headless.js",
        "build:clean": "rm -rf dist && npm run build",
        "start": "webpack serve --mode development",
        "preview": "npm run build && npx http-server -p 4133 -o index.html --cors",
        "serve": "npx http-server . -p 4133 -c-1 --cors -H \"Access-Control-Expose-Headers: *\"",
        "express": "node scripts/express-serve.js",
        "test": "jest"
    },
    "jest": {
        "testEnvironment": "node",
        "transform": {
            "^.+\\.[jt]sx?$": "babel-jest"
        },
        "moduleNameMapper": {
            "\\.(css|less)$": "<rootDir>/scripts/fileMock.js",
            "@wxcc-desktop/sdk": "<rootDir>/scripts/sdkMock.js"
        },
        "testMatch": [
            "**/src/__tests__/**/*.test.js"
        ]
    },
    "dependencies": {
        "@momentum-ui/core": "^19.16.1",
        "@momentum-ui/icons": "^8.33.0",
        "@momentum-ui/react": "^23.27.12",
        "@reduxjs/toolkit": "^1.9.5",
        "@wxcc-desktop/sdk": "^2.0.11",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-redux": "^8.1.2",
        "redux": "^4.2.1"
    },
    "devDependencies": {
        "@babel/core": "^7.22.0",
        "@babel/plugin-proposal-decorators": "^7.22.0",
        "@babel/preset-env": "^7.22.0",
        "@babel/preset-react": "^7.22.0",
        "@rollup/plugin-babel": "^6.0.3",
        "@rollup/plugin-commonjs": "^25.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.1.0",
        "@rollup/plugin-replace": "^6.0.2",
        "@rollup/plugin-terser": "^0.4.4",
        "babel-loader": "^9.1.0",
        "css-loader": "^6.8.0",
        "http-server": "^14.1.1",
        "jest": "^27.0.0",
        "rollup": "^2.0.0",
        "rollup-plugin-postcss": "^4.0.2",
        "rollup-plugin-terser": "^7.0.0",
        "style-loader": "^3.3.0",
        "webpack": "^5.0.0",
        "webpack-cli": "^4.0.0",
        "webpack-dev-server": "^4.15.0"
    }
}
